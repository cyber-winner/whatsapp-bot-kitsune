MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?appName=<AppName>
GEMINI_API_KEY=
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
CONTROL_CENTRE_PASSWORD=<long-random-admin-password>
INTERNAL_API_TOKEN=<long-random-internal-token>
USER_SESSION_TTL_MS=604800000
OTP_TTL_MS=300000
OTP_REQUEST_COOLDOWN_MS=60000
OTP_MAX_REQUESTS_PER_HOUR=5
OTP_MAX_ATTEMPTS=5
ALLOW_HOST_POWER_CONTROL=false
ENABLE_REMOTE_LOGGING=true
RECEIVER_URL=http://localhost:3200

BOT_PREFIX=
BOT_FATHER=
BOT_AGGRESSIVE_COMMANDS=
BOT_ACTIVATE_PHRASE=
BOT_DEACTIVATE_PHRASE=
GIF_API_BASE=
SNIPE_LIMIT=
SNIPE_EXPIRY_MS=
DATA_DIR=
API_HOST=127.0.0.1
WA_API_PORT=3300
CORE_API_PORT=3400
BRAIN_PORT=3100
VIBE_REWARDS_API_KEY=

